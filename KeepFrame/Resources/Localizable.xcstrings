    "photo_access_short_description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "KeepFrame needs access to your photo library to display your photos for review. Swipe to keep, favorite, or mark for deletion, your photos stay on your device and are never uploaded anywhere."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "KeepFrame potrzebuje dostępu do Twojej biblioteki zdjęć, aby wyświetlać je do przeglądu. Przeciągaj, aby zachować, dodać do ulubionych lub oznaczyć do usunięcia, Twoje zdjęcia pozostają na urządzeniu i nigdy nie są nigdzie wysyłane."
          }
        }
      }
    },
